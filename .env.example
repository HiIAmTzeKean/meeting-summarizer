# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Claude authentication (choose one) ────────────────────────────────────────
#
# Option A — direct Anthropic API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B — Claude Max subscription proxy (no API key required)
# Run the proxy locally: npm install -g opencode-claude-max-proxy && meridian
# ANTHROPIC_API_KEY=x
# ANTHROPIC_BASE_URL=http://127.0.0.1:3456
# ──────────────────────────────────────────────────────────────────────────────

# HuggingFace token (required for speaker diarization)
# Get yours at: https://huggingface.co/settings/tokens
# Also accept model terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# Slack webhook URL (optional)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Notion integration (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Whisper model size: tiny, base, small, medium, large
# Recommended: medium (best speed/accuracy for English + Chinese)
WHISPER_MODEL=medium

# Meeting language(s): auto, en, zh, or comma-separated e.g. en,zh
# Use "auto" to let Whisper detect automatically
MEETING_LANGUAGE=auto
